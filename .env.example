# Server Configuration
PORT=3000
# HTTPS_PORT=3443   # omit in production (nginx terminates TLS)
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://node76.cs.colman.ac.il

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/plants-web
# Production (college server, port 21771, @ in password URL-encoded as %40):
# MONGO_URI=mongodb://admin:bartar20%40CS@127.0.0.1:21771/plants-web?authSource=admin

# JWT Configuration
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# OAuth Configuration (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Production: GOOGLE_CALLBACK_URL=https://node76.cs.colman.ac.il/api/auth/google/callback

# OAuth Configuration (Facebook)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
# Production: FACEBOOK_CALLBACK_URL=https://node76.cs.colman.ac.il/api/auth/facebook/callback

# AI Configuration (Gemini)
GEMINI_API_KEY=your-gemini-api-key
